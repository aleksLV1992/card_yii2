parameters:
    level: 6
    paths:
        - actions/
        - assets/
        - config/
        - controllers/
        - views/
        - web/index.php
    excludePaths:
        - vendor/
        - runtime/
        - web/assets/
    bootstrapFiles:
        - phpstan-bootstrap.php
    ignoreErrors:
        -
            message: '#^Ternary operator condition is always true\.$#'
            path: config/web.php
            identifier: ternary.alwaysTrue

